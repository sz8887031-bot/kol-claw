# 飞书配置模板
# 复制此文件为 .env.feishu 并填入实际值

# 飞书应用凭证（必需）
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 飞书用户ID（可选）
FEISHU_USER_ID=your_user_id_here

# 飞书 Webhook（可选，用于群消息推送）
FEISHU_WEBHOOK_URL=

# 飞书多维表格配置（可选，有默认值）
FEISHU_APP_TOKEN=your_app_token_here
FEISHU_TABLE_1_ID=your_table_1_id_here
FEISHU_TABLE_2_ID=your_table_2_id_here
